show_commands() {
    # Detect package manager and show appropriate help
    PACKAGE_MANAGER=$(detect_distro)
    
    if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        show_commands_arch
    elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        show_commands_fedora
    else
        cat << EOF
    🔹 Linux Package Manager (lpm) 🔹
    Automates system updates, upgrades, and cleanup tasks across distributions.

    📌 Usage:
      lpm [OPTION]

    🛠️ Options:
      -h, --help             Show this help message.
      -v, --version          Show script version.

    🔧 System Maintenance
    (no args)   Update, upgrade and clean all

    📚 Available options

    clean       Clean downloaded .deb packages from cache
    cache:stats Show cache statistics

    📦 Package Management
    pkg:install [PACKAGE]      Install a package
    pkg:installed              List installed packages
    pkg:upgrade [PACKAGE]      Upgrade specific package
    pkg:remove [PACKAGE]       Remove a package
    pkg:find [PACKAGE]         Search for a package
    pkg:download [PACKAGE]     Download package source code
    pkg:dependencies [PACKAGE] Check package dependencies
    pkg:description [PACKAGE]  Show package description
    pkg:descriptions           List all packages with descriptions

    🔄 PPA Management
    ppa:list          List configured PPAs
    ppa:install [PPA] Add a PPA
    ppa:remove [PPA]  Remove a PPA

    💾 Memory Management
    freemem         Free up memory

    📊 Monitoring
    sys-info        Show system information
    disk-usage      Show disk usage by partition
    memory-info     Show detailed memory usage

    🛡️ Security
    ufw-status       Show UFW status
    ports-list       List open ports and associated services
    check-updates    Check for security updates
    killport <port>  Kill process using a port

    ⚙️ Services
    service-list          List active services
    service-restart <srv> Restart a service

    💡 Tip: Replace [PACKAGE] with package name and [PPA] with PPA path
    🔗 Repository: https://github.com/alexperezortuno/linux-package-manager
EOF
    fi
}

case "$PARAM_1" in
    -v|--version)
        echo -e "${Yel}Version 1.0.0${RCol}\n";
    ;;
    "clean")
      echo -e "${Yel}";
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        sudo pacman -Sc --noconfirm
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        sudo dnf clean all
      else
        sudo apt autoremove; sudo apt clean; sudo apt autoclean
      fi
      echo -e "${RCol}";
    ;;
    "package:remove")
      if [[ "$PARAM_2" != "" ]]
      then
        echo -e "${Yel}Removing package ${PARAM_2}${RCol}\n";
        PACKAGE_MANAGER=$(detect_distro)
        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
          sudo pacman -Rns "$PARAM_2"
        elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
          sudo dnf remove "$PARAM_2" -y
        else
          sudo apt remove --purge "$PARAM_2"
          sudo apt autoremove
          sudo apt clean
        fi
      else
        echo -e "${Yel}Please tell me what package you want to remove${RCol}\n";
        exit 1
      fi
    ;;
    "package:install")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        sudo pacman -S --noconfirm "${PARAM_2}"
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        sudo dnf install -y "${PARAM_2}"
      else
        sudo apt install "${PARAM_2}"
      fi
    ;;
    "package:upgrade")
      if [[ "$PARAM_2" != "" ]]
      then
        echo -e "${Yel}Installing package ${PARAM_2}${RCol}\n";
        PACKAGE_MANAGER=$(detect_distro)
        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
          sudo pacman -S --noconfirm "$PARAM_2"
        elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
          sudo dnf update "$PARAM_2" -y
        else
          sudo apt install "$PARAM_2" --only-upgrade
        fi
      else
        echo -e "${Red}Please tell me what package you need information${RCol}\n";
        exit 1
      fi
    ;;
    "package:installed")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        pacman -Q | less
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        dnf list installed | less
      else
        sudo apt list --installed | less
      fi
    ;;
    "package:find")
      if [[ "$PARAM_2" != "" ]]
      then
        echo -e "${Yel}Finding package ${PARAM_2}${RCol}\n";
        PACKAGE_MANAGER=$(detect_distro)
        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
          pacman -Qqs "$PARAM_2"
        elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
          dnf list "$PARAM_2" | grep -i "$PARAM_2"
        else
          sudo apt list --installed | grep -i "$PARAM_2"
        fi
      else
        echo -e "${Red}Please tell me what package you need to find${RCol}\n";
        exit 1
      fi
    ;;
    "package:description")
      if [[ "$PARAM_2" != "" ]]
      then
        echo -e "${Yel}Finding package ${PARAM_2}${RCol}\n";
        PACKAGE_MANAGER=$(detect_distro)
        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
          pacman -Qi "$PARAM_2" | less
        elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
          dnf info "$PARAM_2" | less
        else
          apt-cache show "$PARAM_2" | less
        fi
      else
        echo -e "${Red}Please tell me what package you need information${RCol}\n";
        exit 1
      fi
    ;;
    "package:descriptions")
      if [[ "$PARAM_2" != "" ]]
      then
        echo -e "${Yel}Finding package ${PARAM_2}${RCol}\n";
        PACKAGE_MANAGER=$(detect_distro)
        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
          pacman -Si "$PARAM_2" | less
        elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
          dnf search "$PARAM_2" | less
        else
          apt-cache search "$PARAM_2" | less
        fi
      else
        echo -e "${Red}Please tell me what package you need to find${RCol}\n";
        exit 1
      fi
    ;;
    "package:dependencies")
      if [[ "$PARAM_2" != "" ]]
      then
        PACKAGE_MANAGER=$(detect_distro)
        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
          pactree "$PARAM_2" | less
        elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
          dnf repoquery --requires "$PARAM_2" | less
        else
          apt-cache showpkg "$PARAM_2" | less
        fi
      else
        echo -e "${Red}Please tell me what package you need to see${RCol}\n";
        exit 1
      fi
    ;;
    "package:download")
      if [[ "$PARAM_2" != "" ]]
      then
        PACKAGE_MANAGER=$(detect_distro)
        if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
          echo -e "${Yel}Downloading package ${PARAM_2}${RCol}\n";
          pacman -Sw "$PARAM_2" --noconfirm
        elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
          echo -e "${Yel}Downloading package ${PARAM_2}${RCol}\n";
          dnf download "$PARAM_2"
        else
          sudo apt-get --download-only source "$PARAM_2"
        fi
      else
        echo -e "${Red}Please tell me what package needs to download${RCol}\n";
        exit 1
      fi
    ;;
    "package:list")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        pacman -Q
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        dnf list installed
      else
        dpkg --list
      fi
    ;;
    "ppa:list")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Yel}PPAs are not used in Arch Linux${RCol}\n";
        echo -e "${Yel}Use /etc/pacman.conf for repository configuration${RCol}\n";
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Yel}RPMFusion and other repos configured in /etc/yum.repos.d/${RCol}\n";
        ls /etc/yum.repos.d/ | grep -E '\.repo$' | head -10
      else
        apt policy
      fi
    ;;
    "ppa:install")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Yel}PPAs are not used in Arch Linux${RCol}\n";
        echo -e "${Yel}Use pacman.conf or AUR helpers instead${RCol}\n";
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Yel}RPM-based systems use repos in /etc/yum.repos.d/${RCol}\n";
        echo -e "${Yel}Use 'dnf install dnf-plugins-core' then 'dnf config-manager --add-repo <repo>'${RCol}\n";
      else
        if [[ "$PARAM_2" != "" ]]
        then
            sudo add-apt-repository ppa:"$PARAM_2" -y
            sudo apt update
        else
            echo -e "${Red}Please need a PPA ${RCol}\n";
            exit 1
        fi
      fi
    ;;
    "ppa:remove")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Yel}PPAs are not used in Arch Linux${RCol}\n";
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Yel}RPM-based systems use repo removal from /etc/yum.repos.d/${RCol}\n";
      else
        if [[ "$PARAM_2" != "" ]]
        then
            sudo add-apt-repository --remove ppa:"$PARAM_2" -y
            sudo apt update
        else
            echo -e "${Red}Please tell me what ppa needs remove${RCol}\n";
            exit 1
        fi
      fi
    ;;
    "cache:stats")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Gre}Pacman cache directory:${RCol}"
        ls -lh /var/cache/pacman/pkg/ | tail -5
        echo -e "\n${Gre}Total packages in cache:${RCol}"
        ls /var/cache/pacman/pkg/ | wc -l
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Gre}DNF cache directory:${RCol}"
        ls -lh /var/cache/dnf/ | tail -5
        echo -e "\n${Gre}Total packages in cache:${RCol}"
        ls /var/cache/dnf/ | wc -l
      else
        apt-cache stats
      fi
    ;;
    "memory:info")
      if [[ "$PARAM_2" != "" ]]
      then
        sudo dmidecode --type 17 | more
      else
        sudo dmidecode --type 17  | grep -i speed
      fi
    ;;
    "killport")
        echo -e "${Yel}Please write port to kill:  ${RCol}\r"
        read -r PORT
        sudo kill -9 "$(sudo lsof -t -i:"${PORT}")"
    ;;
    "freemem")
        free -h
        su -c "echo 3 > /proc/sys/vm/drop_caches && swapoff -a && swapon -a && printf '\n%s\n' 'Ram-cache and Swap Cleared'" root
        free -h
    ;;
    "fix-broken")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Gre}Fixing broken packages...${RCol}"
        sudo pacman -S --overwrite '*' --noconfirm
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Gre}Fixing broken packages...${RCol}"
        sudo dnf distro-sync --noconfirm
      else
        echo -e "${Gre}Fixing broken packages...${RCol}"
        sudo apt --fix-broken install
      fi
    ;;
    "kernel-clean")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Gre}Cleaning old kernels...${RCol}"
        sudo pacman -Rns $(pacman -Qq | grep -E 'linux-lts|linux-zen|linux-hardened' | grep -v $(uname -r | cut -d'-' -f1-2)) --noconfirm 2>/dev/null || echo "No old kernels found"
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Gre}Cleaning old kernels...${RCol}"
        sudo dnf remove $(dnf list --installed | grep -E 'kernel' | grep -v $(uname -r) | awk '{print $1}') --noconfirm 2>/dev/null || echo "No old kernels found"
      else
        sudo apt purge $(dpkg -l | awk '/^ii linux-image-*/{print $2}' | grep -v $(uname -r))
      fi
    ;;
    "repo-check")
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Gre}Checking repository sources...${RCol}"
        sudo pacman -Sy 2>&1 | grep -i "error\|failed"
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Gre}Checking repository sources...${RCol}"
        sudo dnf check-update 2>&1 | grep -i "error\|failed"
      else
        sudo apt update 2>&1 | grep -i "failed\|error"
      fi
    ;;
    "pkg-search")
      [ -z "$2" ] && echo -e "${Red}Error: Package name required${RCol}" && exit 1
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        pacman -Ss "$2"
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        dnf search "$2"
      else
        apt search "$2"
      fi
    ;;
    "sys-info")
      echo -e "${Gre}System Information:${RCol}"
      echo -e "Hostname: $(hostname)"
      echo -e "Uptime: $(uptime -p)"
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        . /etc/os-release
        echo -e "OS: $NAME $VERSION"
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        . /etc/os-release
        echo -e "OS: $NAME $VERSION"
      else
        echo -e "OS: $(lsb_release -d | cut -f2-)"
      fi
      echo -e "Kernel: $(uname -r)"
      echo -e "CPU: $(lscpu | grep 'Model name' | cut -d':' -f2 | xargs)"
    ;;
    "service-list")
      systemctl list-unit-files --type=service --state=enabled
    ;;
    "service-restart")
      [ -z "$2" ] && echo -e "${Red}Error: Service name required${RCol}" && exit 1
      sudo systemctl restart "$2"
    ;;
    "ufw-status")
      sudo ufw status verbose
    ;;
    "ports-list")
      sudo ss -tulnp
    ;;
    "disk-usage")
      df -h
    ;;
    "memory-info")
      echo -e "${Gre}Memory Information:${RCol}"
      echo -e "Total Memory: $(free -h | grep 'Mem' | awk '{print $2}')"
      echo -e "Used Memory: $(free -h | grep 'Mem' | awk '{print $3}')"
      echo -e "Free Memory: $(free -h | grep 'Mem' | awk '{print $4}')"
    ;;
    -h|--help)
        show_commands
    ;;
    *)
      PACKAGE_MANAGER=$(detect_distro)
      if [[ "$PACKAGE_MANAGER" == "pacman" ]]; then
        echo -e "${Yel} Updating packages ${RCol}";
        sudo pacman -Syu --noconfirm
      elif [[ "$PACKAGE_MANAGER" == "dnf" ]]; then
        echo -e "${Yel} Updating packages ${RCol}";
        sudo dnf update -y
      else
        echo -e "${Yel} Updating packages ${RCol}";
        sudo apt update; apt list --upgradable && sudo apt upgrade -y && sudo apt autoremove; sudo apt clean; sudo apt autoclean
      fi
    ;;
esac

exit 0
